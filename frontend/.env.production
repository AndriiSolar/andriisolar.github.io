# Production-Build Konfiguration
#
# WICHTIG: Diese Datei wird für lokale Builds verwendet.
# Für GitHub Actions wird die URL über ein Repository Secret gesetzt:
#   GitHub → Settings → Secrets and variables → Actions → New repository secret
#   Name:  REACT_APP_BACKEND_URL
#   Value: https://dein-backend.onrender.com
#
# Für lokalen Build kannst du hier deine Backend-URL eintragen:
REACT_APP_BACKEND_URL=https://dein-backend.onrender.com
